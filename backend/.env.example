# ── Provider API keys (REQUIRED — never commit real values) ──────────────────
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
GEMINI_API_KEY=

# ── LLM config ───────────────────────────────────────────────────────────────
LLM_MODEL=gemma-4-26b-a4b-it

# ── Provider selection ────────────────────────────────────────────────────────
STT_PROVIDER=deepgram
TTS_PROVIDER=cartesia
LLM_PROVIDER=gemma

# ── Language / persona ────────────────────────────────────────────────────────
DEFAULT_LANGUAGE=en
CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091
PERSONA_SYSTEM_PROMPT=

# ── Pipeline tuning ───────────────────────────────────────────────────────────
INTERRUPTION_SENSITIVITY=0.5
STT_WORD_BOOST=

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
